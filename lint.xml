<?xml version="1.0" encoding="UTF-8"?>
<!--
  Project-wide Android Lint configuration for PawClock.
  Severity overrides only; defaults are kept for everything else.
  See https://developer.android.com/studio/write/lint for the rule catalog.
-->
<lint>
    <!-- ru is the default locale; strings without translations to en will be added incrementally. -->
    <issue id="MissingTranslation" severity="warning" />

    <!-- We will use ImageVector / vector drawables; bitmap warnings can stay as info during early dev. -->
    <issue id="IconMissingDensityFolder" severity="ignore" />

    <!-- The skeleton has many feature modules without resources yet; suppress until UI lands. -->
    <issue id="UnusedResources" severity="warning" />

    <!-- Compose previews can trigger this; we keep it as warning. -->
    <issue id="ComposableLambdaParameterNaming" severity="warning" />
    <issue id="ComposableLambdaParameterPosition" severity="warning" />

    <!-- Hilt/KSP-generated code must not be linted. -->
    <issue id="all">
        <ignore path="**/build/**" />
        <ignore path="**/generated/**" />
    </issue>
</lint>
