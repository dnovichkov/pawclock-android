<?xml version="1.0" encoding="UTF-8"?>
<!--
  Project-wide Android Lint configuration for PawClock.
  Severity overrides only; defaults are kept for everything else.
  See https://developer.android.com/studio/write/lint for the rule catalog.
-->
<lint>
    <!-- ru is the default locale; strings without translations to en will be added incrementally. -->
    <issue id="MissingTranslation" severity="warning" />

    <!-- We will use ImageVector / vector drawables; bitmap warnings can stay as info during early dev. -->
    <issue id="IconMissingDensityFolder" severity="ignore" />

    <!-- The skeleton has many feature modules without resources yet; suppress until UI lands. -->
    <issue id="UnusedResources" severity="warning" />

    <!-- Compose previews can trigger this; we keep it as warning. -->
    <issue id="ComposableLambdaParameterNaming" severity="warning" />
    <issue id="ComposableLambdaParameterPosition" severity="warning" />

    <!-- Task 17 ⚠️: lint detector'ы из lifecycle-lint и compose-runtime-lint бросают
         IncompatibleClassChangeError на Kotlin 2.0.21 + AGP 8.7.3 + Compose 1.11.1
         из-за binary-incompat с Kotlin Analysis API (KaCallableMemberCall,
         KaSimpleVariableAccessCall, KaFunctionCall). Сами проблемы НЕ применимы:
         мы не используем LiveData и Compose code-style правила проверяются ktlint'ом.
         Включить обратно когда Kotlin bump → 2.1.x (тогда AGP 8.8+ lint совпадёт). -->
    <issue id="NullSafeMutableLiveData" severity="ignore" />
    <issue id="FlowOperatorInvokedInComposition" severity="ignore" />
    <issue id="FrequentlyChangedStateReadInComposition" severity="ignore" />
    <issue id="FrequentlyChangingValue" severity="ignore" />
    <issue id="ProduceStateDoesNotAssignValue" severity="ignore" />
    <issue id="MutableCollectionMutableState" severity="ignore" />
    <issue id="AutoboxingStateCreation" severity="ignore" />
    <issue id="OpaqueUnitKey" severity="ignore" />
    <issue id="UnrememberedMutableState" severity="ignore" />
    <issue id="RememberReturnType" severity="ignore" />
    <issue id="RememberInComposition" severity="ignore" />
    <issue id="UnrememberedMutableInteractionSource" severity="ignore" />
    <issue id="ComposableLambdaParameterPosition" severity="ignore" />
    <issue id="ComposableNaming" severity="ignore" />
    <issue id="StateFlowValueCalledInComposition" severity="ignore" />
    <issue id="CompositionLocalNaming" severity="ignore" />

    <!-- Hilt/KSP-generated code must not be linted. -->
    <issue id="all">
        <ignore path="**/build/**" />
        <ignore path="**/generated/**" />
    </issue>
</lint>
